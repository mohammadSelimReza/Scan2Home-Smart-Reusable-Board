          "item": [
            {
              "name": "Login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Access Token is captured\", function () {",
                      "    var jsonResponse = pm.response.json();",
                      "    var accessToken = jsonResponse.access;",
                      "    var refreshToken = jsonResponse.refresh;",
                      "    ",
                      "    console.log(\"Access Token:\", accessToken);",
                      "    console.log(\"Refresh Token:\",refreshToken);",
                      "    if (accessToken) {",
                      "        pm.collectionVariables.set(\"access_token\", accessToken);",
                      "    } else {",
                      "        console.log(\"Access token not found in response.\");",
                      "    }",
                      "    if (refreshToken){",
                      "        pm.collectionVariables.set(\"refresh_token\",refreshToken);",
                      "    }",
                      "    else{",
                      "        console.log(\"Refresh Token set failed\");",
                      "    }",
                      "",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "auth": {
                  "type": "noauth"
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"srreza1999@gmail.com\",\n  \"password\": \"selim.reza.uits@gmail.com\"\n}"
                },
